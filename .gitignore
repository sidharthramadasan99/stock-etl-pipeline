# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.env
venv/
.venv/

# Data files (we don't commit raw data to Git)
data/raw/*
data/processed/*
logs/*

# Keep the folder structure in Git
!data/raw/.gitkeep
!data/processed/.gitkeep
!logs/.gitkeep

# AWS credentials - NEVER commit these
.aws/
*.csv
*.parquet